---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projetos = await getCollection('projetos');
  return projetos.map(p => ({
    params: { slug: p.id },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const data = project.data as Record<string, any>;

const {
  titulo = "Projeto Analytics",
  objetivo = "Descrição do projeto.",
  competencias = [],
} = data;

const resumoCard = data.resumoCard ?? objetivo;
---

<html lang="pt-BR" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{titulo} — Lucas Souza da Hora</title>
        
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">

        <style is:global>
            body { font-family: 'Inter', sans-serif; }
            h1, h2, h3, h4, h5, h6, .font-display { font-family: 'Space Grotesk', sans-serif; }
        </style>
    </head>
    <body class="bg-[#F8FAFC] text-slate-800 min-h-screen font-sans antialiased">

        <nav class="bg-[#0A1128]/95 border-b border-slate-800/60 py-4 px-6 sticky top-0 z-50 backdrop-blur-md">
            <div class="max-w-4xl mx-auto flex justify-between items-center">
                <a href="/" class="flex items-center gap-2 font-bold text-white text-lg group font-display">
                    <span class="text-[#9D4EDD] group-hover:scale-110 transition-transform duration-300">📊</span> Lucas<span class="text-slate-400 font-normal group-hover:text-[#9D4EDD] transition-colors duration-300">.data</span>
                </a>
                <div class="flex items-center gap-4 text-sm font-medium text-slate-300">
                    <a href="/" class="hover:text-[#9D4EDD] transition-colors duration-300 flex items-center gap-1 group">
                        <span class="group-hover:-translate-x-0.5 transition-transform">←</span> Voltar para o Início
                    </a>
                </div>
            </div>
        </nav>

        <div class="bg-[#0A1128] text-white py-24 px-6 relative overflow-hidden border-b border-slate-900">
            <div class="absolute inset-0 bg-gradient-to-br from-[#0D1B3E] via-[#0A1128] to-[#050A1A] opacity-80"></div>
            
            <header class="max-w-3xl mx-auto relative z-10 space-y-5">
                <div class="inline-flex items-center gap-2 text-[10px] font-bold text-purple-400 uppercase tracking-widest font-display">Caso de Estudo Detalhado</div>
                <h1 class="text-3xl md:text-5xl font-bold tracking-tight leading-tight">{titulo}</h1>
                <p class="text-slate-400 text-base md:text-lg leading-relaxed max-w-2xl font-normal">{resumoCard}</p>
                <div class="flex flex-wrap gap-2 pt-2">
                    {competencias.map((comp: string) => (
                        <span class="text-xs font-semibold px-3 py-1 bg-purple-950/40 text-[#C77DFF] rounded-md border border-purple-800/50 shadow-sm">{comp}</span>
                    ))}
                </div>
            </header>
        </div>

        <main class="max-w-3xl mx-auto px-6 py-12 space-y-8">
            
            <section class="bg-white rounded-2xl shadow-[0_1px_3px_rgba(0,0,0,0.05)] border border-slate-100 p-8 md:p-12">
                <div class="documentacao-container text-slate-600 text-sm md:text-base leading-relaxed space-y-6
                    [&_h3]:font-display [&_h3]:text-xl [&_h3]:font-bold [&_h3]:text-slate-900 [&_h3]:pt-8 [&_h3]:pb-2 [&_h3]:mb-4 [&_h3]:flex [&_h3]:items-center [&_h3]:gap-2 [&_h3]:border-t [&_h3]:border-slate-100/80 first:[&_h3]:border-t-0 first:[&_h3]:pt-0
                    [&_h4]:font-display [&_h4]:text-base [&_h4]:font-bold [&_h4]:text-slate-800 [&_h4]:pt-4 [&_h4]:pb-1 [&_h4]:mb-2
                    [&_p]:mb-6 [&_p]:leading-relaxed
                    
                    {/* LISTAS E QUEBRAS DE LINHA */}
                    [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-3 [&_ul]:my-4 [&_ul_li]:pl-1 [&_ul_strong]:text-slate-800
                    
                    {/* SELETORES DE IMAGEM */}
                    [&_img]:block [&_img]:max-w-xl [&_img]:w-full [&_img]:h-auto [&_img]:rounded-2xl [&_img]:border [&_img]:border-slate-200/60 [&_img]:shadow-md [&_img]:mx-auto [&_img]:mt-8 [&_img]:mb-0
                    
                    {/* LEGENDA VIA SMALL ESTILIZADA E DIFERENCIADA */}
                    [&_p_small]:block [&_p_small]:text-center [&_p_small]:text-[12px] [&_p_small]:text-slate-400 [&_p_small]:italic [&_p_small]:mt-2 [&_p_small]:mb-8
                ">
                    <Content />
                </div>
            </section>
            
        </main>

        <footer class="bg-[#F8FAFC] py-16 px-6 border-t border-slate-100 text-center text-xs text-slate-400">
            <div class="max-w-3xl mx-auto">© 2026 · Lucas Souza da Hora · Portfólio de People Analytics</div>
        </footer>
    </body>
</html>